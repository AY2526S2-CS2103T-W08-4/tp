<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT" spacing="12" styleClass="card-pane">
  <padding>
    <Insets top="10" right="14" bottom="10" left="14" />
  </padding>

  <StackPane minWidth="40" minHeight="40" maxWidth="40" maxHeight="40"
             styleClass="avatar-circle">
    <Label fx:id="avatarLabel" styleClass="avatar-label" />
  </StackPane>

  <VBox spacing="3" HBox.hgrow="ALWAYS">
    <HBox alignment="CENTER_LEFT" spacing="8">
      <Label fx:id="id" styleClass="cell-index-label" />
      <Label fx:id="name" styleClass="cell-primary-label" />
      <Label fx:id="membershipStatus" />
    </HBox>
    <Label fx:id="membershipId" styleClass="cell-membership-id-label" />
    <Label fx:id="membershipExpiryDate" styleClass="cell-secondary-label" />
    <Label fx:id="address" styleClass="cell-secondary-label" />
    <HBox spacing="8" alignment="CENTER_LEFT">
      <Label fx:id="phone" styleClass="cell-secondary-label" />
      <Label text="·" styleClass="cell-secondary-label" />
      <Label fx:id="email" styleClass="cell-secondary-label" />
    </HBox>
  </VBox>
</HBox>
